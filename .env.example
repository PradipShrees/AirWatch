# Copy this file to `.env` and fill in real values.

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airwatch_app:CHANGE_ME@localhost:5432/airwatch

# ── Kafka ─────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092

# ── JWT auth (generate with: openssl rand -hex 32) ────────────────────
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_HEX_STRING

# ── Email alerts (Resend.com) ─────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
ALERT_TO_EMAIL=you@example.com
ALERT_FROM_EMAIL=AirWatch <onboarding@resend.dev>

# ── Sensor device id ──────────────────────────────────────────────────
DEVICE_ID=pi-001
